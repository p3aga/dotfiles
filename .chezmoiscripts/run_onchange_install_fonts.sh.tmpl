#!/bin/bash

# {{ include "fonts/maple-mono-nerd.tar.gz" | sha256sum }}

if [ ! -d "$HOME/.local/share/fonts" ]; then
    echo "Creating fonts directory"
    mkdir -p "$HOME/.local/share/fonts"
fi

echo "Installing fonts"
tar -xzf "{{ .chezmoi.sourceDir }}/fonts/maple-mono-nerd.tar.gz" -C "$HOME/.local/share/fonts"